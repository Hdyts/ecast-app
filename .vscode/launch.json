{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "eCast: Run FastAPI Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "eCast: Download Models",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/download_models.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "eCast: Run Evaluation",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_evaluation.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
